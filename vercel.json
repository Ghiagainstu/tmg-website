{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "tuyuesouxin.cn"
        }
      ],
      "destination": "https://www.tuyuesouxin.cn/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/blog/:slug",
      "destination": "/blog/:slug.html"
    },
    {
      "source": "/blog/:slug/",
      "destination": "/blog/:slug.html"
    },
    {
      "source": "/ja/blog/:slug",
      "destination": "/ja/blog/:slug.html"
    },
    {
      "source": "/ja/blog/:slug/",
      "destination": "/ja/blog/:slug.html"
    },
    {
      "source": "/ko/blog/:slug",
      "destination": "/ko/blog/:slug.html"
    },
    {
      "source": "/ko/blog/:slug/",
      "destination": "/ko/blog/:slug.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "s-maxage=3600, stale-while-revalidate=86400"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "s-maxage=31536000, immutable"
        }
      ]
    },
    {
      "source": "/favicon\\.(ico|svg)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "s-maxage=86400, stale-while-revalidate=604800"
        }
      ]
    }
  ]
}
